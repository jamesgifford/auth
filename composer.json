{
    "name": "jamesgifford/auth",
    "description": "Reusable authentication scaffolding for Laravel applications. Provides public ID generation, account management, invitations, and registration flows.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "James Gifford",
            "email": "james@jamesgifford.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/console": "^13.0",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/support": "^13.0",
        "nikic/php-parser": "^5.0"
    },
    "require-dev": {
        "laravel/pint": "^1.13",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "JamesGifford\\Auth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JamesGifford\\Auth\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "format": "vendor/bin/pint",
        "format:check": "vendor/bin/pint --test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "JamesGifford\\Auth\\AuthServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
